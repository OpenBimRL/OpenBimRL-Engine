ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('Minimal pathfinding test: two doors in connecting walls'),'2;1');
FILE_NAME('pathfinding_minimal.ifc','2026-06-20T00:00:00',('OpenBimRL'),('OpenBimRL'),'OpenBimRL-Engine','','');
FILE_SCHEMA(('IFC4'));
ENDSEC;

DATA;
/* --- units & project --- */
#1=IFCCARTESIANPOINT((0.,0.,0.));
#2=IFCDIRECTION((1.,0.,0.));
#3=IFCDIRECTION((0.,1.,0.));
#4=IFCDIRECTION((0.,0.,1.));
#5=IFCAXIS2PLACEMENT3D(#1,$,$);
#6=IFCGEOMETRICREPRESENTATIONCONTEXT($,'Model',3,1.E-5,#5,#3);
#7=IFCSIUNIT(*,.LENGTHUNIT.,$,.METRE.);
#8=IFCSIUNIT(*,.AREAUNIT.,$,.SQUARE_METRE.);
#9=IFCSIUNIT(*,.VOLUMEUNIT.,$,.CUBIC_METRE.);
#10=IFCUNITASSIGNMENT((#7,#8,#9));
#11=IFCPERSON($,'OpenBimRL',$,$,$,$,$,$);
#12=IFCORGANIZATION($,'OpenBimRL',$,$,$);
#13=IFCPERSONANDORGANIZATION(#11,#12,$);
#14=IFCAPPLICATION(#12,'1.0','OpenBimRL-Engine','OpenBimRL');
#15=IFCOWNERHISTORY(#13,#14,$,.NOCHANGE.,$,$,$,0);
#16=IFCPROJECT('0PathTest000000000001',#15,'Pathfinding Minimal',$,$,$,$,(#6),#10);
#17=IFCAXIS2PLACEMENT3D(#1,$,$);
#18=IFCLOCALPLACEMENT($,#17);
#19=IFCSITE('0PathTest000000000002',#15,'Site',$,$,#18,$,$,.ELEMENT.,$,$,$,$,$);
#20=IFCLOCALPLACEMENT(#18,#17);
#21=IFCBUILDING('0PathTest000000000003',#15,'Building',$,$,#20,$,$,.ELEMENT.,$,$,$);
#22=IFCLOCALPLACEMENT(#20,#17);
#23=IFCBUILDINGSTOREY('0PathTest000000000004',#15,'Ground Floor',$,$,#22,$,$,.ELEMENT.,0.);
#24=IFCLOCALPLACEMENT(#22,#17);
#25=IFCRELAGGREGATES('0PathTest000000000005',#15,$,$,#16,(#19));
#26=IFCRELAGGREGATES('0PathTest000000000006',#15,$,$,#19,(#21));
#27=IFCRELAGGREGATES('0PathTest000000000007',#15,$,$,#21,(#23));

/* Building: 10 m x 6 m footprint, 3 m height, 0.2 m wall thickness
   Room A [0,4] | corridor [4,6] | Room B [6,10] along X
   Doors at y = 2.5 m in partition walls at x = 4 m and x = 6 m */

/* profile helpers – IfcRectangleProfileDef is centred on its Position */
#28=IFCCARTESIANPOINT((0.,0.));
#29=IFCDIRECTION((1.,0.));
#30=IFCAXIS2PLACEMENT2D(#28,#29);
#31=IFCRECTANGLEPROFILEDEF(.AREA.,'HorizWall',#30,10.,0.2);
#32=IFCDIRECTION((0.,1.));
#33=IFCAXIS2PLACEMENT2D(#28,#32);
#34=IFCRECTANGLEPROFILEDEF(.AREA.,'VertWall',#33,6.,0.2);
#35=IFCAXIS2PLACEMENT3D(#1,$,$);
#36=IFCEXTRUDEDAREASOLID(#31,#35,#4,3.);

/* South wall – y = 0.1 m */
#37=IFCCARTESIANPOINT((5.,0.1,0.));
#38=IFCAXIS2PLACEMENT3D(#37,$,$);
#39=IFCLOCALPLACEMENT(#24,#38);
#40=IFCSHAPEREPRESENTATION(#6,'Body','SweptSolid',(#36));
#41=IFCPRODUCTDEFINITIONSHAPE($,$,(#40));
#42=IFCWALL('0PathTest000000000010',#15,'South Wall',$,$,#39,#41,$,$);

/* North wall – y = 5.9 m */
#43=IFCCARTESIANPOINT((5.,5.9,0.));
#44=IFCAXIS2PLACEMENT3D(#43,$,$);
#45=IFCLOCALPLACEMENT(#24,#44);
#46=IFCSHAPEREPRESENTATION(#6,'Body','SweptSolid',(#36));
#47=IFCPRODUCTDEFINITIONSHAPE($,$,(#46));
#48=IFCWALL('0PathTest000000000011',#15,'North Wall',$,$,#45,#47,$,$);

/* West wall – x = 0.1 m */
#49=IFCEXTRUDEDAREASOLID(#34,#35,#4,3.);
#50=IFCCARTESIANPOINT((0.1,3.,0.));
#51=IFCAXIS2PLACEMENT3D(#50,$,$);
#52=IFCLOCALPLACEMENT(#24,#51);
#53=IFCSHAPEREPRESENTATION(#6,'Body','SweptSolid',(#49));
#54=IFCPRODUCTDEFINITIONSHAPE($,$,(#53));
#55=IFCWALL('0PathTest000000000012',#15,'West Wall',$,$,#52,#54,$,$);

/* East wall – x = 9.9 m */
#56=IFCCARTESIANPOINT((9.9,3.,0.));
#57=IFCAXIS2PLACEMENT3D(#56,$,$);
#58=IFCLOCALPLACEMENT(#24,#57);
#59=IFCSHAPEREPRESENTATION(#6,'Body','SweptSolid',(#49));
#60=IFCPRODUCTDEFINITIONSHAPE($,$,(#59));
#61=IFCWALL('0PathTest000000000013',#15,'East Wall',$,$,#58,#60,$,$);

/* Partition wall 1 – x = 4.0 m */
#62=IFCCARTESIANPOINT((4.,3.,0.));
#63=IFCAXIS2PLACEMENT3D(#62,$,$);
#64=IFCLOCALPLACEMENT(#24,#63);
#65=IFCSHAPEREPRESENTATION(#6,'Body','SweptSolid',(#49));
#66=IFCPRODUCTDEFINITIONSHAPE($,$,(#65));
#67=IFCWALL('0PathTest000000000014',#15,'Partition Wall 1',$,$,#64,#66,$,$);

/* Partition wall 2 – x = 6.0 m */
#68=IFCCARTESIANPOINT((6.,3.,0.));
#69=IFCAXIS2PLACEMENT3D(#68,$,$);
#70=IFCLOCALPLACEMENT(#24,#69);
#71=IFCSHAPEREPRESENTATION(#6,'Body','SweptSolid',(#49));
#72=IFCPRODUCTDEFINITIONSHAPE($,$,(#71));
#73=IFCWALL('0PathTest000000000015',#15,'Partition Wall 2',$,$,#70,#72,$,$);

/* Door opening geometry – 1 m wide (along Y), centred on opening placement */
#74=IFCRECTANGLEPROFILEDEF(.AREA.,'DoorOpening',#33,1.,0.2);
#75=IFCEXTRUDEDAREASOLID(#74,#35,#4,2.1);
#76=IFCSHAPEREPRESENTATION(#6,'Body','SweptSolid',(#75));
#77=IFCPRODUCTDEFINITIONSHAPE($,$,(#76));

/* Door 1 – world centre (4, 2.5, 0): partition centre (4,3) + local (0,-0.5) */
#78=IFCCARTESIANPOINT((0.,-0.5,0.));
#79=IFCAXIS2PLACEMENT3D(#78,$,$);
#80=IFCLOCALPLACEMENT(#64,#79);
#81=IFCOPENINGELEMENT('0PathTest000000000020',#15,'Door Opening 1',$,'Opening',#80,#77,$);
#82=IFCRELVOIDSELEMENT('0PathTest000000000021',#15,$,$,#67,#81);
#83=IFCLOCALPLACEMENT(#80,#5);
#84=IFCDOOR('0PathTest000000000022',#15,'Door 1',$,$,#83,#77,'D1',2.1,1.);
#85=IFCRELFILLSELEMENT('0PathTest000000000023',#15,$,$,#81,#84);

/* Door 2 – world centre (6, 2.5, 0) */
#86=IFCCARTESIANPOINT((0.,-0.5,0.));
#87=IFCAXIS2PLACEMENT3D(#86,$,$);
#88=IFCLOCALPLACEMENT(#70,#87);
#89=IFCOPENINGELEMENT('0PathTest000000000024',#15,'Door Opening 2',$,'Opening',#88,#77,$);
#90=IFCRELVOIDSELEMENT('0PathTest000000000025',#15,$,$,#73,#89);
#91=IFCLOCALPLACEMENT(#88,#5);
#92=IFCDOOR('0PathTest000000000026',#15,'Door 2',$,$,#91,#77,'D2',2.1,1.);
#93=IFCRELFILLSELEMENT('0PathTest000000000027',#15,$,$,#89,#92);

#94=IFCRELCONTAINEDINSPATIALSTRUCTURE('0PathTest000000000030',#15,$,$,(#42,#48,#55,#61,#67,#73,#81,#84,#89,#92),#23);
ENDSEC;
END-ISO-10303-21;
